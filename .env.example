# Pizza Count – Umgebungsvariablen
# Kopiere diese Datei als .env und fülle die Werte aus.

# ─── Auth ────────────────────────────────────────────────────────────────────
# Auth.js Secret (mindestens 32 Zeichen, zufällig generiert)
# Erzeugen mit: openssl rand -base64 32
AUTH_SECRET=dein-geheimes-secret-hier-ersetzen

# Bei Reverse-Proxy / Cloudflare Tunnel auf true lassen.
AUTH_TRUST_HOST=true
# Exakte öffentliche HTTPS-URL (Tunnel-Domain). Muss matchen, sonst brechen Cookies/CSRF.
NEXTAUTH_URL=https://your-domain.com

# ─── Datenbank ───────────────────────────────────────────────────────────────
DATABASE_URL="file:/data/db/pizza.db"

# ─── Setup-Guard ─────────────────────────────────────────────────────────────
# /setup ist nur erreichbar, solange kein Admin existiert UND SETUP_ENABLED != false.
# Nach der Erst-Einrichtung hier auf "false" setzen, um die Route komplett abzuschalten.
SETUP_ENABLED=true

# ─── Brute-Force-Schutz (alle optional, Defaults siehe lib/brute-force.ts) ──
# Email-Lockout: N Fehlversuche im Zeitfenster sperren die Email temporär.
LOGIN_EMAIL_MAX_FAILS=5
LOGIN_EMAIL_WINDOW_MIN=15
# IP-Lockout: N Fehlversuche im Zeitfenster sperren die IP temporär.
LOGIN_IP_MAX_FAILS=20
LOGIN_IP_WINDOW_MIN=10

# ─── Litestream (optional, nur bei --profile backup) ─────────────────────────
# S3/B2-Replik-Konfiguration. Empfehlung: Backblaze B2 (S3-kompatibel, günstig).
LITESTREAM_REPLICA_URL=s3://my-bucket/pizza
LITESTREAM_ENDPOINT=https://s3.us-west-000.backblazeb2.com
LITESTREAM_REGION=us-west-000
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=
